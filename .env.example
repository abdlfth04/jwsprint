# Production defaults
APP_DEBUG=false
# Set true only during the first setup if optional tables need to be bootstrapped automatically.
APP_SCHEMA_AUTO_MIGRATE=false
APP_FORCE_HTTPS=true
APP_SECURITY_HEADERS_ENABLED=true
APP_ENABLE_HSTS=true
APP_SESSION_SECURE=true

# Backup hardening
# Keep web backup download off unless you really need it on a trusted admin environment.
APP_ALLOW_BACKUP_DOWNLOAD=false
APP_ALLOW_BACKUP_RESTORE=false

# Private storage should point outside the public web root.
# Example cPanel: /home/CPANEL_USER/.jws_private
APP_PRIVATE_STORAGE_PATH=/home/CPANEL_USER/.jws_private

# Database credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name
